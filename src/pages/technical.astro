---
import Base from '../layouts/Base.astro';

// NDS 2024 Allowable Axial Loads — 6' to 12' only
// Source: QAI Code Evaluation Report CERUS-1064, Table 2
// Values converted from kips: 1 kip = 1,000 lbs = 453.6 kg

const lrfdRows = [
  { span: "6'",  m: '1.8 m', s66_lbs: '60,000', s66_kg: '27,200', s88_lbs: '92,100', s88_kg: '41,800' },
  { span: "8'",  m: '2.4 m', s66_lbs: '48,500', s66_kg: '22,000', s88_lbs: '85,800', s88_kg: '38,900' },
  { span: "10'", m: '3.0 m', s66_lbs: '35,200', s66_kg: '16,000', s88_lbs: '73,800', s88_kg: '33,500' },
  { span: "12'", m: '3.7 m', s66_lbs: '25,500', s66_kg: '11,600', s88_lbs: '58,700', s88_kg: '26,600' },
];

const asdRows = [
  { span: "6'",  m: '1.8 m', s66_lbs: '35,600', s66_kg: '16,100', s88_lbs: '53,800', s88_kg: '24,400' },
  { span: "8'",  m: '2.4 m', s66_lbs: '30,300', s66_kg: '13,700', s88_lbs: '51,000', s88_kg: '23,100' },
  { span: "10'", m: '3.0 m', s66_lbs: '22,900', s66_kg: '10,400', s88_lbs: '45,500', s88_kg: '20,600' },
  { span: "12'", m: '3.7 m', s66_lbs: '16,800', s66_kg: '7,600',  s88_lbs: '37,600', s88_kg: '17,100' },
];

const docs = [
  {
    product: 'Seamless Fascia Post',
    files: [
      { label: 'Installation & Handling Guide',       type: 'Install Guide',  href: '/docs/fascia-post-install-guide.pdf' },
      { label: '15-Year Limited Warranty',            type: 'Warranty',       href: '/docs/fascia-post-warranty.pdf' },
      { label: 'Code Evaluation Report — CERUS-1064', type: 'Cert Report',    href: '/docs/fascia-post-structural-cert.pdf' },
    ],
  },
  {
    product: 'Seamless Cedar Timbers',
    files: [
      { label: 'Installation & Handling Guide', type: 'Install Guide', href: '/docs/cedar-timbers-install-guide.pdf' },
      { label: '25-Year Limited Warranty',      type: 'Warranty',      href: '/docs/cedar-timbers-warranty.pdf' },
      { label: 'Vertical-Use Spec Sheet',        type: 'Spec Sheet',    href: '/docs/cedar-timbers-vertical-use-spec.pdf' },
    ],
  },
];
---

<Base
  title="Technical — Seamless™ Engineered Timbers"
  description="Third-party tested, code-evaluated structural data for Seamless engineered timber posts. NDS 2024 compliant. CERUS-1064 by QAI Laboratories."
>

  <!-- HEADER -->
  <section class="max-w-7xl mx-auto px-6 pt-16 pb-14 border-b border-line">
    <div class="eyebrow mb-4">Technical Resources</div>
    <h1 class="text-5xl md:text-6xl font-medium tracking-tighter-2 leading-[0.95] max-w-2xl mb-6">
      Structural data.<br />
      <span class="italic text-cedar">No asterisks.</span>
    </h1>
    <p class="text-lg text-smoke max-w-2xl">
      Third-party tested and code-evaluated by QAI Laboratories. Everything your engineer,
      architect, or building official needs to spec Seamless into a project with confidence.
    </p>
  </section>

  <!-- CERT STRIP -->
  <div class="border-b border-line">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-line">
        <div class="py-6 px-4 first:pl-0">
          <div class="eyebrow text-ash mb-1">Report No.</div>
          <div class="font-medium text-sm">CERUS-1064</div>
        </div>
        <div class="py-6 px-4">
          <div class="eyebrow text-ash mb-1">Issued by</div>
          <div class="font-medium text-sm">QAI Laboratories</div>
        </div>
        <div class="py-6 px-4">
          <div class="eyebrow text-ash mb-1">Applicable Codes</div>
          <div class="font-medium text-sm">2024 / 2021 / 2018 IBC · IRC</div>
        </div>
        <div class="py-6 px-4">
          <div class="eyebrow text-ash mb-1">CSI Section</div>
          <div class="font-medium text-sm">06 11 13 — Engineered Wood Products</div>
        </div>
      </div>
    </div>
  </div>

  <!-- LOAD TABLE -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-b border-line">
    <div class="eyebrow mb-4">Allowable Axial Loads</div>
    <h2 class="text-3xl md:text-4xl font-medium tracking-tighter-2 mb-3">
      Seamless Fascia Post — SPF
    </h2>
    <p class="text-smoke mb-12 max-w-2xl">
      NDS 2024. Uniform concentric loading. Pin connections top and bottom.
      6×6 and 8×8 cross-sections. Spans 6′–12′.
    </p>

    <div class="grid md:grid-cols-2 gap-10 md:gap-16">

      <!-- LRFD -->
      <div>
        <div class="flex items-center gap-2 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-cedar flex-shrink-0"></span>
          <span class="eyebrow">LRFD — Load Resistance Factor Design</span>
        </div>
        <div class="border-t border-ink">
          <div class="grid grid-cols-3 py-3 border-b border-line">
            <div class="eyebrow text-ash">Span</div>
            <div class="eyebrow text-ash text-right">6×6</div>
            <div class="eyebrow text-ash text-right">8×8</div>
          </div>
          {lrfdRows.map((row) => (
            <div class="grid grid-cols-3 py-4 border-b border-line last:border-b-0">
              <div>
                <div class="font-medium text-sm">{row.span}</div>
                <div class="text-[11px] text-ash mt-0.5">{row.m}</div>
              </div>
              <div class="text-right">
                <div class="font-medium text-sm">{row.s66_lbs} lbs</div>
                <div class="text-[11px] text-ash mt-0.5">{row.s66_kg} kg</div>
              </div>
              <div class="text-right">
                <div class="font-medium text-sm">{row.s88_lbs} lbs</div>
                <div class="text-[11px] text-ash mt-0.5">{row.s88_kg} kg</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ASD -->
      <div>
        <div class="flex items-center gap-2 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-cedar flex-shrink-0"></span>
          <span class="eyebrow">ASD — Allowable Stress Design</span>
        </div>
        <div class="border-t border-ink">
          <div class="grid grid-cols-3 py-3 border-b border-line">
            <div class="eyebrow text-ash">Span</div>
            <div class="eyebrow text-ash text-right">6×6</div>
            <div class="eyebrow text-ash text-right">8×8</div>
          </div>
          {asdRows.map((row) => (
            <div class="grid grid-cols-3 py-4 border-b border-line last:border-b-0">
              <div>
                <div class="font-medium text-sm">{row.span}</div>
                <div class="text-[11px] text-ash mt-0.5">{row.m}</div>
              </div>
              <div class="text-right">
                <div class="font-medium text-sm">{row.s66_lbs} lbs</div>
                <div class="text-[11px] text-ash mt-0.5">{row.s66_kg} kg</div>
              </div>
              <div class="text-right">
                <div class="font-medium text-sm">{row.s88_lbs} lbs</div>
                <div class="text-[11px] text-ash mt-0.5">{row.s88_kg} kg</div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Source note -->
    <div class="mt-10 pt-6 border-t border-line text-[11px] text-ash leading-relaxed max-w-3xl">
      Source: QAI Laboratories Code Evaluation Report CERUS-1064 · Seamless Post by CureWood Engineered Building Products Ltd. ·
      Published January 2026. Evaluated per ASTM D5456 and ANSI/AWC National Design Specification (NDS) for Wood Construction.
      Factors applied: C<sub>D</sub> = 1.0 · C<sub>M</sub> = 1.0 · C<sub>t</sub> = 1.0 · c = 0.9.
      Conditions outside these parameters require Engineering Design per the authority having jurisdiction.
    </div>

    <!-- Fascia Post documents -->
    <div class="mt-12 grid md:grid-cols-3 gap-4">
      {docs[0].files.map((doc) => (
        <a href={doc.href} target="_blank" rel="noopener"
          class="flex flex-col border border-line p-6 hover:border-ink transition-colors group">
          <div class="eyebrow text-ash mb-3">{doc.type}</div>
          <div class="text-lg font-medium group-hover:text-cedar transition-colors">{doc.label} →</div>
        </a>
      ))}
    </div>
  </section>

  <!-- CEDAR VERTICAL-USE TABLE -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-b border-line">
    <div class="eyebrow mb-4">Vertical-Use Performance</div>
    <h2 class="text-3xl md:text-4xl font-medium tracking-tighter-2 mb-3">
      Seamless Cedar Timbers — Western Red Cedar
    </h2>
    <p class="text-smoke mb-12 max-w-2xl">
      Section-area estimates for vertical-use applications using net Western Red Cedar area
      and conservative No.2 WRC timber design values.
    </p>

    <div class="border-t border-ink mb-4">
      <div class="grid grid-cols-4 py-3 border-b border-line">
        <div class="eyebrow text-ash">Size</div>
        <div class="eyebrow text-ash">Net size</div>
        <div class="eyebrow text-ash">Net WRC area</div>
        <div class="eyebrow text-ash text-right">Vertical-use indication</div>
      </div>
      <div class="grid grid-cols-4 py-4 border-b border-line">
        <div class="font-medium text-sm">4×4</div>
        <div class="text-sm text-smoke">3-1/2″ × 3-1/2″</div>
        <div class="text-sm text-smoke">12.25 in²</div>
        <div class="text-sm font-medium text-right">Approx. 6,700 lb</div>
      </div>
      <div class="grid grid-cols-4 py-4 border-b border-line">
        <div class="font-medium text-sm">6×6</div>
        <div class="text-sm text-smoke">5-1/2″ × 5-1/2″</div>
        <div class="text-sm text-smoke">24.00 in²</div>
        <div class="text-sm font-medium text-right">Approx. 13,200 lb</div>
      </div>
      <div class="grid grid-cols-4 py-4">
        <div class="font-medium text-sm">8×8</div>
        <div class="text-sm text-smoke">7-1/4″ × 7-1/4″</div>
        <div class="text-sm text-smoke">34.50 in²</div>
        <div class="text-sm font-medium text-right">Approx. 19,000 lb</div>
      </div>
    </div>

    <div class="mt-4 pt-6 border-t border-line text-[11px] text-ash leading-relaxed max-w-3xl">
      Vertical-use indication is a section-area estimate using net Western Red Cedar area and a conservative No.2 WRC
      compression-parallel value of 550 psi. Final use is subject to project-specific design, connection details,
      installation conditions, and local code requirements.
      Vertical use indications not provided by QAI.
    </div>

    <!-- Quality / manufacturing confidence -->
    <div class="mt-12 pt-10 border-t border-line">
      <div class="flex items-center gap-4 mb-8">
        <div class="eyebrow">Quality System &amp; Manufacturing Confidence</div>
        <div class="text-[11px] text-ash">· Audited and inspected by QAI Laboratories</div>
      </div>
      <div class="space-y-5 text-smoke leading-relaxed">
        <p>Each Seamless™ Cedar Timber is manufactured using the same disciplined production approach developed through CureWood's QAI-evaluated Seamless™ structural post program. This includes controlled adhesive application, adhesive performance checks, dimensional verification, routine quality checks, and ongoing manufacturing oversight.</p>
        <p>For the Seamless™ Cedar Timber product line, that means the laminated seams, bonded faces, and assembled post geometry are produced under a controlled and repeatable manufacturing process designed to support long-term bond integrity and dimensional consistency. Builders, designers, and end users can have confidence that the product is not simply a decorative wrap, but an engineered cedar post manufactured with verified process controls and third-party quality oversight.</p>
        <p>For vertical-use applications, the substantial net Western Red Cedar section provides a rational engineering basis for estimating compression performance using recognized #2/Btr Western Red Cedar timber design values. Final use, connection details, and project-specific loading should be reviewed by the project designer, engineer of record, or local authority having jurisdiction.</p>
      </div>
    </div>

    <!-- Cedar documents -->
    <div class="mt-12 grid md:grid-cols-3 gap-4">
      {docs[1].files.map((doc) => (
        <a href={doc.href} target="_blank" rel="noopener"
          class="flex flex-col border border-line p-6 hover:border-ink transition-colors group">
          <div class="eyebrow text-ash mb-3">{doc.type}</div>
          <div class="text-lg font-medium group-hover:text-cedar transition-colors">{doc.label} →</div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <h2 class="text-4xl md:text-5xl font-medium tracking-tighter-2 mb-4">
      Need more? <span class="italic text-cedar">Talk to us.</span>
    </h2>
    <p class="text-lg text-smoke max-w-xl mb-8">
      Additional engineering data, project-specific questions, or samples —
      our team answers the phone.
    </p>
    <a href="/contact" class="btn-primary">Contact us →</a>
  </section>

</Base>
