---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — Seamless™ by CureWood">
  <section class="max-w-7xl mx-auto px-6 pt-16 pb-24">
    <div class="eyebrow mb-4">Contact</div>
    <h1 class="text-5xl md:text-6xl font-medium tracking-tighter-2 max-w-3xl mb-12">
      Talk to <span class="italic text-cedar">a human.</span>
    </h1>

    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <div class="eyebrow mb-3">Sales & samples</div>
        <p class="text-smoke leading-relaxed mb-6">
          For pricing, samples, lead times, or to spec Seamless into a project.
        </p>
        <ul class="space-y-2 text-lg">
          <li><a href="mailto:technical@curewood.co" class="hover:text-cedar transition-colors">technical@curewood.co</a></li>
          <li>+1-250-732-0310</li>
        </ul>
      </div>

      <div>
        <div class="eyebrow mb-3">Location</div>
        <p class="text-smoke leading-relaxed mb-6">
          Designed, engineered, and manufactured on the West Coast.
        </p>
        <ul class="space-y-2 text-lg">
          <li>Vancouver, British Columbia</li>
          <li>Canada</li>
        </ul>
      </div>
    </div>
  </section>
</Base>
