---
import Base from '../layouts/Base.astro';
import { products, productOrder } from '../data/products.js';

const productList = productOrder.map((slug) => products[slug]);

// All hero images cycle in the background — field shots first, then product shots
const heroImages = [
  '/images/products/fascia-post/hero_1.png',
  '/images/products/fascia-post/hero_2.png',
  '/images/products/fascia-post/hero_3.png',
  '/images/products/cedar-timbers/hero_1.png',
  '/images/products/cedar-timbers/hero_2.png',
  '/images/products/cedar-timbers/hero_3.png',
  '/images/products/cedar-timbers/hero_4.png',
];
---

<Base title="Seamless™ — Engineered Timbers by CureWood">

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="height: 88vh; min-height: 560px;">

    {/* Crossfading background images */}
    {heroImages.map((src, i) => (
      <img
        src={src}
        alt="Seamless engineered timbers in the field"
        class="absolute inset-0 w-full h-full object-cover object-center"
        style={`opacity: ${i === 0 ? '1' : '0'}; transition: opacity 1.8s ease;`}
        data-hero-slide={i}
      />
    ))}

    {/* Gradient — darkens bottom so text is readable over any photo */}
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(20,18,16,0.88) 0%, rgba(20,18,16,0.35) 45%, rgba(20,18,16,0.08) 100%);"
    ></div>

    {/* Hero content — pinned to bottom-left */}
    <div class="absolute bottom-0 left-0 right-0">
      <div class="max-w-7xl mx-auto px-6 pb-14">
        <div class="flex items-center gap-2 mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-cedar"></span>
          <span class="eyebrow" style="color: rgba(240,234,224,0.65);">
            In production · Vancouver · 2026 batch shipping
          </span>
        </div>
        <h1 class="text-bone text-6xl md:text-8xl font-medium leading-[0.93] tracking-tightest">
          A timber.
        </h1>
        <h1 class="text-cedar text-6xl md:text-8xl font-medium leading-[0.93] tracking-tightest italic mb-6">
          Just better.
        </h1>
        <p class="text-lg leading-snug max-w-xl mb-9" style="color: rgba(240,234,224,0.72);">
          Hollow-core engineered posts and timbers. The look of old-growth,
          without cutting any. Five species. One warranty that outlasts the trim crew.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/products" class="btn-primary">Browse products →</a>
          <a href="/contact" class="btn-secondary">Request samples</a>
        </div>
      </div>
    </div>

    {/* Slide counter dots */}
    <div class="absolute bottom-6 right-6 flex gap-1.5" id="hero-dots">
      {heroImages.map((_, i) => (
        <div
          class="hero-dot"
          style={`width:5px;height:5px;border-radius:50%;background:${i===0 ? 'rgba(240,234,224,0.85)' : 'rgba(240,234,224,0.3)'};transition:background 0.4s;`}
        ></div>
      ))}
    </div>
  </section>

  <script>
    const slides = Array.from(document.querySelectorAll<HTMLImageElement>('[data-hero-slide]'));
    const dots   = Array.from(document.querySelectorAll<HTMLElement>('.hero-dot'));
    if (slides.length > 1) {
      let cur = 0;
      setInterval(() => {
        slides[cur].style.opacity = '0';
        dots[cur].style.background = 'rgba(240,234,224,0.3)';
        cur = (cur + 1) % slides.length;
        slides[cur].style.opacity = '1';
        dots[cur].style.background = 'rgba(240,234,224,0.85)';
      }, 5500);
    }
  </script>

  <!-- ── PRODUCT STRIP ──────────────────────────────────────────────────── -->
  <div class="border-b border-ink">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-5">
        {productList.map((p, i) => (
          <a
            href={`/products/${p.slug}`}
            class={`group p-5 border-r border-line last:border-r-0 hover:bg-[#f5f0e8] transition-colors ${i === productList.length - 1 ? 'bg-ink text-bone' : ''}`}
          >
            <div class={`eyebrow ${i === productList.length - 1 ? 'text-ash' : ''}`}>
              {p.name.replace('Seamless ', '').replace('Timber-Lite ', '')}
            </div>
            <div class="text-sm mt-1.5">
              {p.sizes.map((s) => s.replace('x', '×')).join(' · ')}
            </div>
            <div class={`text-[11px] mt-0.5 ${i === productList.length - 1 ? 'text-ash' : 'text-smoke'}`}>
              {p.colors[0]}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── STATS BAR ──────────────────────────────────────────────────────── -->
  <div class="border-b border-line">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-line">
        <div class="py-6 px-4 first:pl-0">
          <div class="text-3xl font-medium tracking-tighter-2">25yr</div>
          <div class="eyebrow text-ash mt-1">Limited warranty</div>
        </div>
        <div class="py-6 px-4">
          <div class="text-3xl font-medium tracking-tighter-2">5</div>
          <div class="eyebrow text-ash mt-1">Species lines</div>
        </div>
        <div class="py-6 px-4">
          <div class="text-3xl font-medium tracking-tighter-2">4×4→8×8</div>
          <div class="eyebrow text-ash mt-1">Full-sawn sizes</div>
        </div>
        <div class="py-6 px-4">
          <div class="text-3xl font-medium tracking-tighter-2">0</div>
          <div class="eyebrow text-ash mt-1">Site-wrapping needed</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── PRODUCTS GRID ──────────────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="mb-12">
      <div class="eyebrow mb-2">The collection</div>
      <h2 class="text-4xl md:text-5xl font-medium tracking-tighter-2">
        Five lines. <span class="italic text-cedar">One warranty.</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {productList.map((p) => (
        <a href={`/products/${p.slug}`} class="group block border border-line hover:border-ink transition-colors duration-200">
          {/* Photo */}
          <div class="bg-[#ede9e2] overflow-hidden" style="aspect-ratio: 4/3;">
            {p.featuredImage ? (
              <img
                src={p.featuredImage}
                alt={p.name}
                class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500 ease-out"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-[#a89f93] text-[10px] eyebrow tracking-widest">Photo coming soon</span>
              </div>
            )}
          </div>
          {/* Info */}
          <div class="p-5 border-t border-line">
            <div class="eyebrow text-ash mb-1">{p.species}</div>
            <div class="font-medium text-lg mb-1.5 group-hover:text-cedar transition-colors duration-200">
              {p.name} →
            </div>
            <div class="text-sm text-smoke leading-snug">{p.tagline}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── WHY SEAMLESS ───────────────────────────────────────────────────── -->
  <section class="border-t border-line">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="eyebrow mb-3">Why Seamless</div>
      <h2 class="text-4xl md:text-5xl font-medium tracking-tighter-2 max-w-2xl mb-14">
        Old-growth aesthetics. <span class="italic text-cedar">Second-growth ethics.</span>
      </h2>
      <div class="grid md:grid-cols-3 gap-10">
        <div class="border-t-2 border-cedar pt-6">
          <div class="text-cedar font-medium text-sm mb-3">01 / The look</div>
          <p class="text-smoke leading-relaxed">
            Full-sawn faces, color-matched grain, no seams or site-wrapping.
            Reads as a single solid timber from every angle that matters.
          </p>
        </div>
        <div class="border-t-2 border-cedar pt-6">
          <div class="text-cedar font-medium text-sm mb-3">02 / The build</div>
          <p class="text-smoke leading-relaxed">
            Hollow-core construction means stable, lighter, and dimensionally
            honest. Run wires through the middle. Cut it with standard tools.
          </p>
        </div>
        <div class="border-t-2 border-cedar pt-6">
          <div class="text-cedar font-medium text-sm mb-3">03 / The deal</div>
          <p class="text-smoke leading-relaxed">
            25-year limited warranty against manufacturing defects and joint
            separation. Responsibly-sourced second-growth fiber — not old-growth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────── -->
  <section class="bg-ink text-bone py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl md:text-6xl font-medium tracking-tighter-2 mb-4">
        Spec it. Sample it. <span class="italic text-cedar">Ship it.</span>
      </h2>
      <p class="text-lg max-w-xl mb-9" style="color: rgba(240,234,224,0.65);">
        Talk to our team about pricing, lead times, samples, or technical questions.
        We answer the phone.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Talk to sales →</a>
        <a href="/contact" class="btn-secondary">Request samples</a>
      </div>
    </div>
  </section>

</Base>
