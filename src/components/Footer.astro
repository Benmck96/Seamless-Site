---
const year = new Date().getFullYear();
---

<footer class="bg-ink text-bone mt-32">
  <div class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-4 gap-12">
    <div class="md:col-span-2">
      <div class="text-2xl font-medium tracking-tightest">SEAMLESS<span class="text-cedar">™</span></div>
      <p class="text-sm text-ash mt-3 max-w-xs leading-relaxed">
        Engineered timber that looks like the real thing — because it is.
        Manufactured in Vancouver, BC by CureWood Engineered Building Products.
      </p>
    </div>
    <div>
      <div class="eyebrow mb-4">Explore</div>
      <ul class="space-y-2 text-sm">
        <li><a href="/products" class="hover:text-cedar transition-colors">Products</a></li>
        <li><a href="/technical" class="hover:text-cedar transition-colors">Technical</a></li>
        <li><a href="/projects" class="hover:text-cedar transition-colors">Projects</a></li>
        <li><a href="/sustainability" class="hover:text-cedar transition-colors">Sustainability</a></li>
        <li><a href="/warranty" class="hover:text-cedar transition-colors">Warranty</a></li>
      </ul>
    </div>
    <div>
      <div class="eyebrow mb-4">Contact</div>
      <ul class="space-y-2 text-sm">
        <li>+1-250-732-0310</li>
        <li><a href="mailto:technical@curewood.co" class="hover:text-cedar transition-colors">technical@curewood.co</a></li>
        <li>Vancouver, BC</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-smoke">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center text-[11px] text-ash uppercase tracking-wider-2">
      <span>© {year} CureWood Engineered Building Products</span>
      <span>Made in BC</span>
    </div>
  </div>
</footer>
