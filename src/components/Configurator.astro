---
export interface Props {
  product: {
    slug: string;
    name: string;
    sizes: string[];
    finishes: string[];
    colors: string[];
    lengths: string;
    warranty: string;
    photos?: Record<string, string>;
  };
}

const { product } = Astro.props;
const showColors = product.colors.length > 1;
const isTimberLite = product.slug === 'timber-lite-doug-fir';
const accentClass = isTimberLite ? 'text-ink' : 'text-cedar';
const accentBg = isTimberLite ? 'bg-ink' : 'bg-cedar';

const photos = product.photos ?? {};
const hasPhotos = Object.keys(photos).length > 0;
// Pick the initial photo: match first color, then first entry in the map
const initialSrc = photos[product.colors[0]] ?? Object.values(photos)[0] ?? '';
---

<section class="bg-ink text-bone py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="eyebrow text-ash mb-2">Configure</div>
    <h2 class="text-3xl md:text-4xl font-medium tracking-tighter-2 mb-10">
      Pick your spec.
    </h2>

    {/* Photo map embedded for the client-side script */}
    <div id="product-photos-data" class="hidden" data-photos={JSON.stringify(photos)}></div>

    <div class={`grid gap-8 items-start ${hasPhotos ? 'md:grid-cols-3' : 'md:grid-cols-3'}`}>

      {/* ── Photo panel (left column on desktop, below toggles on mobile) ── */}
      {hasPhotos && (
        <div class="order-2 md:order-1">
          {/* Outer wrapper keeps the 3:4 portrait ratio */}
          <div class="relative overflow-hidden bg-[#ede9e2]" style="aspect-ratio: 3 / 4;">
            {/* Placeholder – visible until a real photo loads */}
            <div
              id="photo-placeholder"
              class="absolute inset-0 flex items-center justify-center"
            >
              <span class="text-[#a89f93] text-[10px] eyebrow tracking-widest">Photo coming soon</span>
            </div>

            {/* The photo itself – starts invisible, fades in on load */}
            <img
              id="product-photo"
              src={initialSrc}
              alt={product.name}
              class="absolute inset-0 w-full h-full object-cover"
              style="opacity: 0; transition: opacity 0.45s ease;"
            />
          </div>
        </div>
      )}

      {/* ── Toggles (first on mobile so users configure before seeing photo) ── */}
      <div class={`order-1 md:order-2 space-y-8 ${!hasPhotos ? 'md:col-span-2' : ''}`}>

        {/* Size */}
        <div>
          <div class="eyebrow text-ash mb-3">Size</div>
          <div class="flex flex-wrap gap-2" data-config-group="size">
            {product.sizes.map((size, i) => (
              <button
                type="button"
                data-config-option={size}
                class={`config-btn px-5 py-3 border text-sm font-medium transition-colors ${i === 0 ? 'is-active' : ''}`}
              >
                {size.replace('x', '×')}
              </button>
            ))}
          </div>
        </div>

        {/* Finish */}
        <div>
          <div class="eyebrow text-ash mb-3">Finish</div>
          <div class="flex flex-wrap gap-2" data-config-group="finish">
            {product.finishes.map((finish, i) => (
              <button
                type="button"
                data-config-option={finish}
                class={`config-btn px-5 py-3 border text-sm font-medium transition-colors ${i === 0 ? 'is-active' : ''}`}
              >
                {finish}
              </button>
            ))}
          </div>
        </div>

        {/* Color */}
        {showColors && (
          <div>
            <div class="eyebrow text-ash mb-3">Color</div>
            <div class="flex flex-wrap gap-2" data-config-group="color">
              {product.colors.map((color, i) => (
                <button
                  type="button"
                  data-config-option={color}
                  class={`config-btn px-5 py-3 border text-sm font-medium transition-colors ${i === 0 ? 'is-active' : ''}`}
                >
                  {color}
                </button>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* ── Live spec panel (right column) ── */}
      <div class="order-3 border border-smoke p-6 bg-ink">
        <div class="eyebrow text-ash mb-4">Selected configuration</div>
        <div class="space-y-3 text-sm mb-6">
          <div class="flex justify-between border-b border-smoke pb-2">
            <span class="text-ash">Size</span>
            <span class="font-medium" data-config-display="size">{product.sizes[0].replace('x', '×')}</span>
          </div>
          <div class="flex justify-between border-b border-smoke pb-2">
            <span class="text-ash">Finish</span>
            <span class="font-medium" data-config-display="finish">{product.finishes[0]}</span>
          </div>
          {showColors && (
            <div class="flex justify-between border-b border-smoke pb-2">
              <span class="text-ash">Color</span>
              <span class="font-medium" data-config-display="color">{product.colors[0]}</span>
            </div>
          )}
          <div class="flex justify-between border-b border-smoke pb-2">
            <span class="text-ash">Lengths</span>
            <span class="font-medium text-right">{product.lengths}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-ash">Warranty</span>
            <span class={`font-medium ${accentClass}`}>{product.warranty}</span>
          </div>
        </div>
        <a
          href="/contact"
          class={`block ${accentBg} text-bone text-center py-3 text-sm font-medium hover:opacity-85 transition-opacity`}
        >
          Request this spec →
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .config-btn {
    background: transparent;
    border-color: var(--smoke);
    color: var(--bone);
    cursor: pointer;
  }
  .config-btn:hover {
    border-color: var(--bone);
  }
  .config-btn.is-active {
    background: var(--bone);
    border-color: var(--bone);
    color: var(--ink);
  }
</style>

<script>
  // ── Photo data ──────────────────────────────────────────────────────────────
  const photoDataEl = document.getElementById('product-photos-data');
  const photos: Record<string, string> = photoDataEl
    ? JSON.parse(photoDataEl.dataset.photos ?? '{}')
    : {};

  const photoImg        = document.getElementById('product-photo')      as HTMLImageElement | null;
  const photoPlaceholder = document.getElementById('photo-placeholder') as HTMLElement | null;

  // Current selections — populated as groups are wired up below
  const selections: Record<string, string> = {};

  function resolvePhotoSrc(): string {
    // Priority: color match → size match → finish match → first photo in map
    return (
      (selections.color   && photos[selections.color])   ||
      (selections.size    && photos[selections.size])    ||
      (selections.finish  && photos[selections.finish])  ||
      Object.values(photos)[0] ||
      ''
    );
  }

  function updatePhoto(src: string) {
    if (!photoImg || !src) return;

    const FADE_MS = 450; // must match the CSS transition duration above

    // If the src hasn't changed, just make sure it's visible
    if (photoImg.src.endsWith(src)) {
      if (parseFloat(photoImg.style.opacity) < 1) {
        photoImg.style.opacity = '1';
        if (photoPlaceholder) photoPlaceholder.style.display = 'none';
      }
      return;
    }

    // Fade out, swap, fade in
    photoImg.style.opacity = '0';

    setTimeout(() => {
      photoImg.src = src;

      photoImg.onload = () => {
        photoImg.style.opacity = '1';
        if (photoPlaceholder) photoPlaceholder.style.display = 'none';
      };

      photoImg.onerror = () => {
        // Image missing — keep placeholder visible
        photoImg.style.opacity = '0';
        if (photoPlaceholder) photoPlaceholder.style.display = '';
      };
    }, FADE_MS);
  }

  // ── Config group wiring ─────────────────────────────────────────────────────
  const groups = document.querySelectorAll('[data-config-group]');

  groups.forEach((group) => {
    const groupName = group.getAttribute('data-config-group')!;
    const display   = document.querySelector(`[data-config-display="${groupName}"]`);
    const buttons   = group.querySelectorAll('.config-btn');

    // Capture the initial active value
    const activeBtn = group.querySelector('.config-btn.is-active') as HTMLButtonElement | null;
    if (activeBtn) {
      selections[groupName] = activeBtn.dataset.configOption ?? '';
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        const value = (btn as HTMLButtonElement).dataset.configOption ?? '';
        selections[groupName] = value;

        if (display) {
          display.textContent = value.replace('x', '×');
        }

        updatePhoto(resolvePhotoSrc());
      });
    });
  });

  // Show the initial photo on page load
  updatePhoto(resolvePhotoSrc());
</script>
