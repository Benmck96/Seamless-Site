---
export interface Props {
  product: {
    slug: string;
    imageFolder: string;
    name: string;
    sizes: string[];
    finishes: string[];
    colors: string[];
    lengths: string;
    warranty: string;
  };
}

const { product } = Astro.props;
const showColors = product.colors.length > 1;
const isTimberLite = product.slug === 'timber-lite-doug-fir';
const accentClass = isTimberLite ? 'text-ink' : 'text-cedar';
const accentBg = isTimberLite ? 'bg-ink' : 'bg-cedar';

// imageFolder is the short folder name (e.g. "fascia-post"), not the full slug.
// Photo naming: Size_Finish_Colour_1.png, _2.png, ... or Size_Finish_Colour.png
const photoBase = `/images/products/${product.imageFolder}/`;
---

<section class="bg-ink text-bone py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="eyebrow text-ash mb-2">Configure</div>
    <h2 class="text-3xl md:text-4xl font-medium tracking-tighter-2 mb-10">
      Pick your spec.
    </h2>

    <div
      id="product-config-data"
      class="hidden"
      data-photo-base={photoBase}
      data-sizes={JSON.stringify(product.sizes)}
      data-finishes={JSON.stringify(product.finishes)}
      data-colors={JSON.stringify(product.colors)}
    ></div>

    <div class="grid md:grid-cols-3 gap-8 items-start">

      {/* ── Photo panel ── */}
      <div class="order-2 md:order-1">
        <div class="relative overflow-hidden bg-[#ede9e2]" style="aspect-ratio: 3 / 4;">
          {/* Placeholder — visible until a photo loads */}
          <div id="photo-placeholder" class="absolute inset-0 flex items-center justify-center">
            <span class="text-[#a89f93] text-[10px] eyebrow tracking-widest">Photo coming soon</span>
          </div>

          {/* Photo — crossfades on selection change, cycles through numbered shots */}
          <img
            id="product-photo"
            src=""
            alt={product.name}
            class="absolute inset-0 w-full h-full object-cover"
            style="opacity: 0; transition: opacity 0.45s ease;"
          />

          {/* Dot indicators — shown only when there are multiple shots */}
          <div id="photo-dots" class="absolute bottom-3 left-0 right-0 flex justify-center gap-1.5 hidden">
          </div>
        </div>
      </div>

      {/* ── Toggles ── */}
      <div class="order-1 md:order-2 space-y-8">

        <div>
          <div class="eyebrow text-ash mb-3">Size</div>
          <div class="flex flex-wrap gap-2" data-config-group="size">
            {product.sizes.map((size, i) => (
              <button
                type="button"
                data-config-option={size}
                class={`config-btn px-5 py-3 border text-sm font-medium transition-colors ${i === 0 ? 'is-active' : ''}`}
              >
                {size.replace('x', '×')}
              </button>
            ))}
          </div>
        </div>

        <div>
          <div class="eyebrow text-ash mb-3">Finish</div>
          <div class="flex flex-wrap gap-2" data-config-group="finish">
            {product.finishes.map((finish, i) => (
              <button
                type="button"
                data-config-option={finish}
                class={`config-btn px-5 py-3 border text-sm font-medium transition-colors ${i === 0 ? 'is-active' : ''}`}
              >
                {finish}
              </button>
            ))}
          </div>
        </div>

        {showColors && (
          <div>
            <div class="eyebrow text-ash mb-3">Color</div>
            <div class="flex flex-wrap gap-2" data-config-group="color">
              {product.colors.map((color, i) => (
                <button
                  type="button"
                  data-config-option={color}
                  class={`config-btn px-5 py-3 border text-sm font-medium transition-colors ${i === 0 ? 'is-active' : ''}`}
                >
                  {color}
                </button>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* ── Spec panel ── */}
      <div class="order-3 border border-smoke p-6 bg-ink">
        <div class="eyebrow text-ash mb-4">Selected configuration</div>
        <div class="space-y-3 text-sm mb-6">
          <div class="flex justify-between border-b border-smoke pb-2">
            <span class="text-ash">Size</span>
            <span class="font-medium" data-config-display="size">{product.sizes[0].replace('x', '×')}</span>
          </div>
          <div class="flex justify-between border-b border-smoke pb-2">
            <span class="text-ash">Finish</span>
            <span class="font-medium" data-config-display="finish">{product.finishes[0]}</span>
          </div>
          {showColors && (
            <div class="flex justify-between border-b border-smoke pb-2">
              <span class="text-ash">Color</span>
              <span class="font-medium" data-config-display="color">{product.colors[0]}</span>
            </div>
          )}
          <div class="flex justify-between border-b border-smoke pb-2">
            <span class="text-ash">Lengths</span>
            <span class="font-medium text-right">{product.lengths}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-ash">Warranty</span>
            <span class={`font-medium ${accentClass}`}>{product.warranty}</span>
          </div>
        </div>
        <a
          href="/contact"
          class={`block ${accentBg} text-bone text-center py-3 text-sm font-medium hover:opacity-85 transition-opacity`}
        >
          Request this spec →
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .config-btn {
    background: transparent;
    border-color: var(--smoke);
    color: var(--bone);
    cursor: pointer;
  }
  .config-btn:hover { border-color: var(--bone); }
  .config-btn.is-active {
    background: var(--bone);
    border-color: var(--bone);
    color: var(--ink);
  }

  .photo-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    transition: background 0.3s;
  }
  .photo-dot.is-active { background: rgba(255,255,255,0.9); }
</style>

<script>
  // ─────────────────────────────────────────────────────────────────────────
  // Constants
  // ─────────────────────────────────────────────────────────────────────────

  const MAX_NUMBERED   = 8;    // max numbered shots to probe per combo (_1 … _8)
  const SLIDE_INTERVAL = 4500; // ms each photo is shown before crossfading
  const FADE_MS        = 450;  // must match the CSS transition above

  // ─────────────────────────────────────────────────────────────────────────
  // DOM refs
  // ─────────────────────────────────────────────────────────────────────────

  const configData       = document.getElementById('product-config-data');
  const photoBase        = configData?.dataset.photoBase ?? '';
  const allSizes         = JSON.parse(configData?.dataset.sizes    ?? '[]') as string[];
  const allFinishes      = JSON.parse(configData?.dataset.finishes ?? '[]') as string[];
  const allColors        = JSON.parse(configData?.dataset.colors   ?? '[]') as string[];
  const photoImg         = document.getElementById('product-photo')      as HTMLImageElement | null;
  const photoPlaceholder = document.getElementById('photo-placeholder')  as HTMLElement | null;
  const dotsEl           = document.getElementById('photo-dots')         as HTMLElement | null;

  // ─────────────────────────────────────────────────────────────────────────
  // Slideshow state
  // ─────────────────────────────────────────────────────────────────────────

  let cyclePhotos: string[]   = [];
  let cycleIdx                = 0;
  let cycleTimer: ReturnType<typeof setInterval> | null = null;
  let loadGeneration          = 0; // cancels stale async loads on rapid selection changes

  // ─────────────────────────────────────────────────────────────────────────
  // Helpers
  // ─────────────────────────────────────────────────────────────────────────

  /** "Rougher Head" → "Rougher-Head" */
  function toFile(s: string): string {
    return s.replace(/\s+/g, '-');
  }

  /** Silent background request; resolves to the src on success, null on 404 */
  function probe(src: string): Promise<string | null> {
    return new Promise(resolve => {
      const img = new Image();
      img.onload  = () => resolve(src);
      img.onerror = () => resolve(null);
      img.src = src;
    });
  }

  /** Try a base path with .jpg then .png; returns whichever loads first, or null */
  function probeExt(base: string): Promise<string | null> {
    return Promise.all([probe(base + '.jpg'), probe(base + '.png')])
      .then(([jpg, png]) => jpg ?? png);
  }

  /** Build fallback base paths (most specific → least specific, no extension) */
  function buildFallbackBases(size: string, finish: string, color: string): string[] {
    const s = toFile(size);
    const f = toFile(finish);
    const c = toFile(color);
    const list: string[] = [];
    if (s && f && c) list.push(`${photoBase}${s}_${f}_${c}`);
    if (f && c)      list.push(`${photoBase}${f}_${c}`);
    if (c)           list.push(`${photoBase}${c}`);
    if (s && f)      list.push(`${photoBase}${s}_${f}`);
    return list;
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Dot indicators
  // ─────────────────────────────────────────────────────────────────────────

  function buildDots(count: number) {
    if (!dotsEl) return;
    dotsEl.innerHTML = '';
    if (count < 2) { dotsEl.classList.add('hidden'); return; }
    dotsEl.classList.remove('hidden');
    for (let i = 0; i < count; i++) {
      const dot = document.createElement('div');
      dot.className = `photo-dot${i === 0 ? ' is-active' : ''}`;
      dotsEl.appendChild(dot);
    }
  }

  function updateDot(idx: number) {
    if (!dotsEl) return;
    dotsEl.querySelectorAll('.photo-dot').forEach((d, i) => {
      d.classList.toggle('is-active', i === idx);
    });
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Photo display
  // ─────────────────────────────────────────────────────────────────────────

  function stopCycle() {
    if (cycleTimer) { clearInterval(cycleTimer); cycleTimer = null; }
  }

  /** Swap to a new src with crossfade; calls back when the image is visible */
  function crossfadeTo(src: string, onVisible?: () => void) {
    if (!photoImg) return;
    photoImg.style.opacity = '0';
    setTimeout(() => {
      photoImg!.src = src;
      photoImg!.onload = () => {
        photoImg!.style.opacity = '1';
        if (photoPlaceholder) photoPlaceholder.style.display = 'none';
        onVisible?.();
      };
    }, FADE_MS);
  }

  /** Display a set of photos and start cycling if more than one */
  function startCycle(photos: string[]) {
    stopCycle();
    cyclePhotos = photos;
    cycleIdx    = 0;

    buildDots(photos.length);

    crossfadeTo(photos[0]);

    if (photos.length > 1) {
      cycleTimer = setInterval(() => {
        cycleIdx = (cycleIdx + 1) % cyclePhotos.length;
        updateDot(cycleIdx);
        crossfadeTo(cyclePhotos[cycleIdx]);
      }, SLIDE_INTERVAL);
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Main load function
  // ─────────────────────────────────────────────────────────────────────────

  const selections: Record<string, string> = {};

  async function loadPhotosForSelection() {
    const gen = ++loadGeneration; // each call gets a unique generation token
    stopCycle();
    if (photoImg) photoImg.style.opacity = '0';

    const size   = selections.size   ?? '';
    const finish = selections.finish ?? '';
    const color  = selections.color  ?? '';

    // Build the most-specific key for numbered shots
    const key = [toFile(size), toFile(finish), toFile(color)].filter(Boolean).join('_');

    // ── Phase 1: probe numbered shots in parallel (_1 … _MAX_NUMBERED) ──────
    // Tries both .jpg and .png for each slot
    if (key) {
      const numberedResults = await Promise.all(
        Array.from({ length: MAX_NUMBERED }, (_, i) =>
          probeExt(`${photoBase}${key}_${i + 1}`)
        )
      );
      if (gen !== loadGeneration) return; // a newer selection already started

      const numbered = numberedResults.filter((r): r is string => r !== null);
      if (numbered.length > 0) {
        startCycle(numbered);
        return;
      }
    }

    // ── Phase 2: try single-image fallback chain ───────────────────────────
    for (const base of buildFallbackBases(size, finish, color)) {
      const result = await probeExt(base);
      if (gen !== loadGeneration) return;
      if (result) {
        startCycle([result]);
        return;
      }
    }

    // ── Phase 3: last resort — try _1 for every possible combo in this product ──
    // Ensures the photo panel is never blank just because the *default* selection
    // doesn't have its own photo yet.
    const allCombos = allSizes.flatMap(sz =>
      allFinishes.flatMap(fn =>
        allColors.map(cl => `${toFile(sz)}_${toFile(fn)}_${toFile(cl)}`)
      )
    );
    const anyResults = await Promise.all(
      allCombos.map(combo => probeExt(`${photoBase}${combo}_1`))
    );
    if (gen !== loadGeneration) return;
    const anyFound = anyResults.find((r): r is string => r !== null);
    if (anyFound) {
      startCycle([anyFound]);
      return;
    }

    // ── Nothing at all — show placeholder ─────────────────────────────────
    if (gen !== loadGeneration) return;
    buildDots(0);
    if (photoPlaceholder) photoPlaceholder.style.display = '';
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Wire up toggle groups
  // ─────────────────────────────────────────────────────────────────────────

  document.querySelectorAll('[data-config-group]').forEach((group) => {
    const groupName = group.getAttribute('data-config-group')!;
    const display   = document.querySelector(`[data-config-display="${groupName}"]`);
    const buttons   = group.querySelectorAll('.config-btn');

    // Seed from the initially-active button
    const active = group.querySelector('.config-btn.is-active') as HTMLButtonElement | null;
    if (active) selections[groupName] = active.dataset.configOption ?? '';

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        const value = (btn as HTMLButtonElement).dataset.configOption ?? '';
        selections[groupName] = value;
        if (display) display.textContent = value.replace('x', '×');

        loadPhotosForSelection();
      });
    });
  });

  // Kick off the initial photo load
  loadPhotosForSelection();
</script>
