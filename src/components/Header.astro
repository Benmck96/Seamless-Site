---
const nav = [
  { label: 'Products', href: '/products' },
  { label: 'Technical', href: '/technical' },
  { label: 'Projects', href: '/projects' },
  { label: 'Sustainability', href: '/sustainability' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      {/* Seamless mark — two overlapping squares, front one hollow (hollow-core cross-section) */}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 34 30" class="h-7 w-auto flex-shrink-0" aria-hidden="true">
        <rect x="0" y="10" width="20" height="20" fill="currentColor" opacity="0.3"/>
        <rect x="14" y="0" width="20" height="20" fill="currentColor"/>
        <rect x="20" y="6" width="8" height="8" fill="white"/>
      </svg>
      <span class="text-2xl font-medium tracking-tightest">SEAMLESS</span>
      <span class="bg-ink text-bone text-[10px] font-medium px-1.5 py-0.5 tracking-wider-1">™</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-ink hover:text-cedar transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hidden md:block eyebrow">by CureWood</div>
  </div>
</header>
