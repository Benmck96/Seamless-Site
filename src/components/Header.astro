---
const nav = [
  { label: 'Products', href: '/products' },
  { label: 'Technical', href: '/technical' },
  { label: 'Projects', href: '/projects' },
  { label: 'Sustainability', href: '/sustainability' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="flex items-baseline gap-2">
      <span class="text-2xl font-medium tracking-tightest">SEAMLESS</span>
      <span class="bg-ink text-bone text-[10px] font-medium px-1.5 py-0.5 tracking-wider-1">™</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-ink hover:text-cedar transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hidden md:block eyebrow">by CureWood</div>
  </div>
</header>
