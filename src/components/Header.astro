---
const nav = [
  { label: 'Products', href: '/products' },
  { label: 'Technical', href: '/technical' },
  { label: 'Sustainability', href: '/sustainability' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="border-b border-line">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 28" class="h-7 w-auto flex-shrink-0" aria-hidden="true">
        <!-- Large black square with hollow core -->
        <rect x="0" y="0" width="21" height="21" fill="#0A0A0A"/>
        <rect x="6" y="6" width="9" height="9" fill="#FAFAF7"/>
        <!-- Orange square with hollow core -->
        <rect x="12" y="8" width="18" height="18" fill="#D4451F"/>
        <rect x="17.5" y="14" width="7" height="7" fill="#FAFAF7"/>
      </svg>
      <span class="text-2xl font-medium tracking-tightest">SEAMLESS<sup class="text-[10px] font-normal align-super">™</sup></span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-ink hover:text-cedar transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hidden md:block eyebrow">by CureWood</div>
  </div>
</header>
